# ── stdio mode credentials (bring your own token) ──────────────────────────────
# A live Salesforce access token and the org instance URL it belongs to.
SF_ACCESS_TOKEN=
SF_INSTANCE_URL=https://your-domain.my.salesforce.com

# ── login (PKCE) ───────────────────────────────────────────────────────────────
# Consumer key of your Salesforce External Client App (ECA).
SF_CLIENT_ID=
# Only for confidential apps; public PKCE clients leave this blank.
SF_CLIENT_SECRET=
# Production: https://login.salesforce.com  |  Sandbox: https://test.salesforce.com
SF_LOGIN_URL=https://login.salesforce.com
SF_SCOPE=api refresh_token
SF_CALLBACK_PORT=1717

# ── optional ───────────────────────────────────────────────────────────────────
SF_API_VERSION=62.0
# Set to 1 to strip create/update/delete tools (recommended for hosted server).
SF_READONLY=
# HTTP host port (used by `http` mode).
PORT=3000
